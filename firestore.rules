rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [헬퍼 함수]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // 이메일 주소 또는 UID를 통해 관리자 권한을 확인합니다.
      return isAuthenticated() && 
             (request.auth.token.email == "cskim1747@gmail.com" || 
              request.auth.uid == "3H9K9FXktGgDrxEkm6zqzGWoaxf1");
    }

    // 1. 가격 정보: 누구나 읽기 가능, 관리자만 수정
    match /pricing/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. 견적/상담 요청: 누구나 생성 가능, 읽기는 '모두' 또는 '관리자'
    match /quotes/{document=**} {
      allow read: if true; 
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // 3. 사용자 프로필: 본인 정보는 본인이 읽고 쓸 수 있어야 함
    // 4. 공지사항: 누구나 읽기 가능, 관리자만 쓰기/수정/삭제 가능
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. 골퍼 명언: 누구나 읽기 가능, 관리자만 쓰기/수정/삭제 가능
    match /golferQuotes/{quoteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}