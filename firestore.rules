rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // [헬퍼 함수]
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // 이메일 주소 또는 UID를 통해 관리자 권한을 확인합니다.
      return isAuthenticated() && 
             (request.auth.token.email == "cskim1747@gmail.com" || 
              request.auth.token.email == "jco119@gmail.com" ||
              request.auth.uid == "3H9K9FXktGgDrxEkm6zqzGWoaxf1");
    }

    // 1. 가격 정보: 누구나 읽기 가능, 관리자만 수정
    match /pricing/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. 견적/상담 요청: 누구나 생성 가능, 읽기는 '본인' 또는 '관리자'
    // (여기서는 단순화를 위해 생성만 누구나 허용하고, 수정/삭제/읽기는 관리자만 가능하도록 제한)
    match /quotes/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 4. 공지사항: 누구나 읽기 가능, 관리자만 쓰기/수정/삭제 가능
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. 골퍼 명언: 누구나 읽기 가능, 관리자만 쓰기/수정/삭제 가능
    match /golferQuotes/{quoteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. 챗봇 데이터: 누구나 읽기 가능, 관리자만 수정
    match /chatting/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. NFC 데스크 세션: 누구나 읽고, 쓰기는 관리자만 가능 (NFC 임시 전송용)
    match /active_sessions/{document=**} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 8. 갤러리 관련: 누구나 읽기 가능, 관리자만 수정
    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videoGallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}